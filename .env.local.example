# 本地开发环境变量
# Supabase 配好后，系统会自动把活动、任务、设计稿、运营提报等数据同步到云端。

SUPABASE_URL="https://你的项目.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="只放服务端使用的 service_role key，不要公开给别人"
SUPABASE_STORAGE_BUCKET="marketing-files"

# 登录鉴权（生产环境必须设置，否则默认口令为 123456）
# APP_LOGIN_PASSWORD：所有账号共用的登录口令，改成别人猜不到的值。
# APP_SESSION_SECRET：会话签名密钥，随便填一长串随机字符；不设则回退用 service_role key。
APP_LOGIN_PASSWORD="改成你自己的登录口令"
APP_SESSION_SECRET="一长串随机字符串-用于给登录会话签名"

DATABASE_URL="postgresql://marketing:marketing_local_password@localhost:5432/marketing_center"
APP_TIMEZONE="Asia/Shanghai"
STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="./uploads"

# 后期上腾讯云时再替换为 COS、短信、钉钉配置。
TENCENT_SECRET_ID=""
TENCENT_SECRET_KEY=""
TENCENT_COS_BUCKET=""
TENCENT_COS_REGION=""
DINGTALK_WEBHOOK_URL=""
DINGTALK_SECRET=""
